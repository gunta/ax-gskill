{
  "name": "ax-gskill",
  "version": "0.1.0",
  "description": "Automatically learn repository-specific skills for coding agents via evolutionary search",
  "type": "module",
  "bin": {
    "ax-gskill": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "run:pipeline": "bun run src/index.ts run",
    "tasks": "bun run src/index.ts tasks",
    "build": "bun build src/index.ts --compile --outfile dist/ax-gskill",
    "test": "bun test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ax-llm/ax": "^16.0.0",
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
